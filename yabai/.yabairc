#!/usr/bin/env sh

yabai -m config mouse_follows_focus on
yabai -m config window_placement second_child
yabai -m config window_opacity on
yabai -m config window_shadow on
yabai -m config active_window_opacity 1.0
yabai -m config normal_window_opacity 1.0
yabai -m config split_ratio 0.50
yabai -m config auto_balance off
yabai -m config window_animation_duration 0.0

yabai -m config layout bsp
yabai -m config top_padding 8
yabai -m config bottom_padding 8
yabai -m config left_padding 8
yabai -m config right_padding 8
yabai -m config window_gap 8
yabai -m config external_bar main:0:0
yabai -m config mouse_modifier fn
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize

# space 1
yabai -m space 1 --label web
yabai -m rule --add app="Safari" space=web

# space 2: development
yabai -m space 2 --label dev
yabai -m rule --add app="Code" space=dev
yabai -m rule --add app="Visual Studio Code" space=dev
yabai -m rule --add app="Ghostty" space=dev

# space 3: out of the way thingys
yabai -m space 3 --label misc
yabai -m space 3 --layout stack
yabai -m rule --add app="Mail" space=misc
yabai -m rule --add app="Slack" space=misc
yabai -m rule --add app="Discord" space=misc
yabai -m rule --add app="Music" space=misc
yabai -m rule --add app="Podcasts" space=misc
yabai -m rule --add app="WhatsApp" space=misc

# things that should not be managed by yabai
yabai -m rule --add label="Safari" app="^Safari$" title="^(General|(Tab|Password|Website|Extension|Profile)s|AutoFill|Se(arch|curity)|Privacy|Advanced|Developer|Feature Flags)$" manage=off
yabai -m rule --add app="^Finder$" manage=off
yabai -m rule --add app="System Settings" manage=off
yabai -m rule --add label="Software Update" title="Software Update" manage=off
yabai -m rule --add label="FaceTime" app="^FaceTime$" title="^FaceTime$" manage=off
